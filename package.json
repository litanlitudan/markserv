{
  "name": "markserv",
  "version": "2.0.0-beta.1",
  "description": "🏁  serve markdown as html (GitHub style), index directories, live-reload as you edit",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "dev": "node --watch lib/cli.js",
    "start": "node lib/cli.js",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "cover": "vitest run --coverage",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "migrate": "node scripts/migrate-to-esm.js",
    "prepare": "husky install",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "code",
    "directory",
    "gfm",
    "github",
    "github flavored markdown",
    "highlighting",
    "html",
    "include",
    "index",
    "indexes",
    "links",
    "live",
    "live-reload",
    "livereload",
    "markdown",
    "markdown-it",
    "marked",
    "markitdown",
    "md",
    "realtime",
    "reload",
    "server",
    "syntax highlighting",
    "template",
    "templating"
  ],
  "husky": {
    "hooks": {
      "pre-commit": "npm test"
    }
  },
  "bin": {
    "markserv": "lib/cli.js",
    "readme": "lib/readme.js"
  },
  "files": [
    "lib/cli.js",
    "lib/cli-defs.js",
    "lib/cli-help.txt",
    "lib/readme.js",
    "lib/server.js",
    "lib/splash.js",
    "lib/icons",
    "lib/templates/directory.html",
    "lib/templates/markdown.html",
    "lib/templates/error.html",
    "lib/templates/github.less",
    "lib/templates/highlight-js-github-gist.css",
    "lib/templates/markserv.css",
    "media/markserv-favicon-96x96.png",
    "media/markserv-logo-term.png"
  ],
  "author": "Alistair MacDonald <al@pwn.io>",
  "email": "al@pwn.io",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "http://github.com/markserv/markserv.git"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "compression": "^1.7.4",
    "express": "^4.21.1",
    "handlebars": "^4.7.8",
    "highlight.js": "^11.10.0",
    "is-online": "^10.0.0",
    "less": "^4.2.0",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-highlightjs": "^4.2.0",
    "markdown-it-include": "^2.0.0",
    "markdown-it-mathjax3": "^4.3.2",
    "markdown-it-table-of-contents": "^0.8.0",
    "markdown-it-task-lists": "^2.1.1",
    "mime-types": "^2.1.35",
    "open": "^10.1.0",
    "ora": "^8.1.0",
    "serve-static": "^1.16.2",
    "ws": "^8.18.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "@vitest/ui": "^2.1.3",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "get-port": "^7.1.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "node-fetch": "^3.3.2",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "tabWidth": 2,
    "useTabs": true
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2024": true
    },
    "extends": [
      "eslint:recommended",
      "prettier"
    ],
    "parserOptions": {
      "ecmaVersion": 2024,
      "sourceType": "module"
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  }
}
